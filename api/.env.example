NODE_ENV=development
PORT=4000

# PostgreSQL (conexión por campos; usada por demo/api)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=concreto_db
DB_USER=postgres
DB_PASSWORD=postgres

# En producción con PostgreSQL en la nube suele ser true
DB_SSL=false

# Cambiar en producción por un secreto largo y aleatorio
JWT_SECRET=cambiar-en-produccion-minimo-8-caracteres
